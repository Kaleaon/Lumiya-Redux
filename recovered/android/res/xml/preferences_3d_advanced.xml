<?xml version="1.0" encoding="utf-8"?>
<PreferenceScreen android:title="@string/prefs_category_3d_advanced"
  xmlns:android="http://schemas.android.com/apk/res/android">
    <CheckBoxPreference android:title="Anti-aliasing" android:key="fxaa_enable" android:summary="Smooth edges at the expense of lower frame rate" android:defaultValue="false" />
    <CheckBoxPreference android:title="Sky clouds" android:key="clouds_enable" android:summary="Render clouds on the sky" android:defaultValue="true" />
    <ListPreference android:entries="@array/pref_render_engine" android:title="Render Engine" android:key="render_engine" android:summary="%s" android:defaultValue="legacy_gles" android:entryValues="@array/pref_render_engine_values" />
    <CheckBoxPreference android:title="Request ANGLE backend" android:key="request_angle" android:summary="Request ANGLE where available, while retaining legacy GLES fallback" android:defaultValue="false" />
    <ListPreference android:entries="@array/pref_time_of_day" android:title="Time of day" android:key="render_time_of_day" android:summary="%s" android:defaultValue="sim" android:entryValues="@array/pref_time_of_day_values" />
</PreferenceScreen>
